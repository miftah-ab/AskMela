# ─── APP CONFIG ───────────────────────────────────────────────────────────────
NODE_ENV=development # development or production
PORT=3000 # Port for the bot server (Render)

# ─── TELEGRAM BOT ────────────────────────────────────────────────────────────
BOT_TOKEN= # Your Telegram Bot Token from @BotFather
WEBHOOK_URL= # Your production URL (e.g., https://askmela-bot.onrender.com)
WEBHOOK_SECRET= # A random string to verify Telegram requests

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
SUPABASE_URL= # Your Supabase project URL
SUPABASE_ANON_KEY= # Your Supabase anonymous key
SUPABASE_SERVICE_ROLE_KEY= # Your Supabase service role key (CRITICAL for bot)

# ─── AI (GROQ) ───────────────────────────────────────────────────────────────
GROQ_API_KEY= # Your Groq API key for RAG processing

# ─── PUBLIC (WEB) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL= # Your Next.js app URL (e.g., https://askmela.vercel.app)
NEXT_PUBLIC_BOT_USERNAME= # Your bot's username without @
NEXT_PUBLIC_SUPABASE_URL= # Same as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Same as SUPABASE_ANON_KEY
