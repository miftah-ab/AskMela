    "react-dom": "^18",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "cloudflared": "^0.7.1",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "localtunnel": "^2.0.2",
    "postcss": "^8",
