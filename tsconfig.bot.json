{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/bot/**/*",
    "src/bot/services/**/*",
    "src/bot/handlers/**/*",
    "src/bot/utils/**/*"
  ],
  "exclude": [
    "node_modules",
    "src/app",
    "src/components",
    "dist",
    ".next"
  ]
}
